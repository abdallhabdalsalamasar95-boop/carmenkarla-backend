# Local Python LAN server
HOST=0.0.0.0
PORT=8080

# Admin token for web panel management routes.
API_TOKEN=change_me_super_secret

# Optional public URL used in uploaded image links.
# Example: https://carmenkarla-backend.onrender.com
SERVER_BASE_URL=

# Persistent storage root (recommended on Render with disk attached)
STORAGE_ROOT=/var/data/carmenkarla

# Optional: e.g. http://192.168.1.20:3000
CORS_ORIGIN=

# Firebase Admin credentials for customer notifications (Firestore writes).
# Option A: absolute path to service-account JSON file.
FIREBASE_SERVICE_ACCOUNT_FILE=

# Option B: raw JSON content (single-line) for service account.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Optional fallback project id (used only when credentials are handled externally).
FIREBASE_PROJECT_ID=

# Catalog storage mode:
# - auto      : use Firestore when credentials are available, otherwise local file.
# - local     : force products.json file only.
# - firestore : force Firestore catalog (recommended for production).
PRODUCTS_STORAGE_MODE=auto

# Firestore collection used for product catalog when PRODUCTS_STORAGE_MODE uses Firestore.
PRODUCTS_FIRESTORE_COLLECTION=products_catalog
