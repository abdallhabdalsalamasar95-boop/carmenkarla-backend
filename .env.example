# Local Python LAN server
HOST=0.0.0.0
PORT=8080

# Must match app setting: Local Catalog API Token
API_TOKEN=change_me_super_secret

# Optional public URL used in uploaded image links.
# Example: https://carmenkarla-backend.onrender.com
SERVER_BASE_URL=

# Optional persistent storage root.
# On Render paid plan with a disk, use something like: /var/data/carmenkarla
STORAGE_ROOT=

# Optional: e.g. http://192.168.1.20:3000
CORS_ORIGIN=
